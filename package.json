{
  "name": "swiggy-prism",
  "version": "1.0.0",
  "description": "Budget-first recipe-to-cart agent for Swiggy Instamart",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "swiggy-prism": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "swiggy",
    "instamart",
    "mcp",
    "recipe",
    "budget",
    "grocery"
  ],
  "author": "Deepanshu Verma",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
