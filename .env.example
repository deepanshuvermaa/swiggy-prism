# LLM Provider (pick one)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Set to "live" to connect to real Swiggy MCP servers (mcp.swiggy.com)
# Set to "mock" (default) for local demo with embedded catalog
# Auth: OAuth 2.1 PKCE — user authenticates via phone+OTP in browser
# No client_id/secret needed — uses Dynamic Client Registration (RFC 7591)
MCP_MODE=mock

# OAuth redirect URI (only needed in live mode)
# Use http://localhost:3000/auth/callback for local dev
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
